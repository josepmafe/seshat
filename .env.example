# PostgreSQL (used by docker-compose and the app)
POSTGRES_USER=seshat
POSTGRES_PASSWORD=seshat
POSTGRES_DB=seshat
POSTGRES_PORT=5432
# host is the Docker service name; port 5432 is container-internal, not POSTGRES_PORT — DB is only accessed from within Docker
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
# Override for local (non-Docker) runs
# POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# MLflow tracking server
MLFLOW_PORT=5000
# Override when running outside Docker (default is http://mlflow:5000 for container use)
# OBSERVABILITY__MLFLOW_TRACKING_URI=http://localhost:${MLFLOW_PORT}

# LocalStack — fake AWS services for local dev and integration tests
LOCALSTACK_PORT=4566
AWS_DEFAULT_REGION=eu-central-1

# AWS resource names (resolved at runtime; LocalStack uses these too)
S3_BUCKET=seshat-mvp

# Secrets backend — use 'env' for local runs (reads secrets from env vars), 'aws' for prod
# SECRETS__PROVIDER=env
# SECRETS__ENDPOINT_URL=http://localhost:${LOCALSTACK_PORT}
# SECRETS__REGION=${AWS_DEFAULT_REGION}

# AI provider credentials and config
## OpenAI
OPENAI_API_KEY=
OPENAI_API_VERSION=

## Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

## Anthropic
ANTHROPIC_API_KEY=

## AWS Bedrock
# AWS_PROFILE=

## AssemblyAI (transcription)
ASSEMBLYAI_API_KEY=

## ElevenLabs (synthetic audio fixtures)
ELEVENLABS_API_KEY=

# Vector index — embedding model
# VECTOR_INDEX__EMBEDDING_PROVIDER=azure_openai
# VECTOR_INDEX__EMBEDDING_MODEL=text-embedding-ada-002

# Extraction LLM config
# EXTRACTION__IDENTIFICATION__PROVIDER=bedrock_converse
# EXTRACTION__IDENTIFICATION__MODEL=eu.anthropic.claude-haiku-4-5-20251001-v1:0
# EXTRACTION__VERIFICATION__PROVIDER=azure_openai
# EXTRACTION__VERIFICATION__MODEL=gpt-4o-mini
# EXTRACTION__RESOLUTION__PROVIDER=bedrock_converse
# EXTRACTION__RESOLUTION__MODEL=eu.anthropic.claude-haiku-4-5-20251001-v1:0
# EXTRACTION__IDENTIFICATION_SELF_REVIEW__ENABLED=false
# EXTRACTION__RESOLUTION_SELF_REVIEW__ENABLED=false

# Confidence threshold for node auto-approval during the identification phase.
# Set by IdentificationMetaScorer calibration (argmax coverage at a given p_target); re-run after enabling verification.
# EXTRACTION__CONFIDENCE_THRESHOLD=

# RAG / retrieval config
# Search mode: semantic (default), keyword, hybrid
# RAG__SEARCH_MODE=semantic
# LLM keyword extractor for sparse leg (required for KEYWORD and HYBRID modes)
# RAG__KEYWORD_EXTRACTION_LLM__PROVIDER=azure_openai
# RAG__KEYWORD_EXTRACTION_LLM__MODEL=gpt-4o-mini
# RAG__MIN_SIMILARITY_SCORE=

# Retrieval eval score thresholds — per-mode, set by RetrievalMetaScorer calibration (argmax macro-F2).
# It depends on the distribution of retrieval scores, which can vary widely across datasets and retriever models,
# so it's not set by default.
# EVAL__RETRIEVAL_SCORE_THRESHOLDS__SEMANTIC=
# EVAL__RETRIEVAL_SCORE_THRESHOLDS__KEYWORD=
# EVAL__RETRIEVAL_SCORE_THRESHOLDS__HYBRID=
