# Copy to .env and fill in the values for local (non-Docker) runs.
# For Docker, copy docker/.env.docker.example to .env.docker instead.

# ── Docker Compose infrastructure ────────────────────────────────────────────

POSTGRES_USER=seshat
POSTGRES_PASSWORD=seshat
POSTGRES_DB=seshat
POSTGRES_PORT=5432
# Container-internal URL used by the migrate service and localstack init
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

API_PORT=8000
MLFLOW_PORT=5000
LOCALSTACK_PORT=4566
AWS_DEFAULT_REGION=eu-central-1
S3_BUCKET=seshat-mvp

# ── API keys ──────────────────────────────────────────────────────────────────

SESHAT_ADMIN_API_KEY=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
OPENAI_API_VERSION=2024-02-01

# for Bedrock provider
# AWS_PROFILE=

ASSEMBLYAI_API_KEY=
ELEVENLABS_API_KEY=

# ── Local-run overrides ───────────────────────────────────────────────────────

# Read secrets from env vars instead of LocalStack/AWS Secrets Manager
SECRETS__PROVIDER=env
SECRETS__ENDPOINT_URL=http://localhost:${LOCALSTACK_PORT}
SECRETS__REGION=${AWS_DEFAULT_REGION}

# Connect to Postgres on localhost instead of the 'postgres' Docker service name
POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# Connect to LocalStack and MLflow on localhost
BLOB_STORE__ENDPOINT_URL=http://localhost:${LOCALSTACK_PORT}
OBSERVABILITY__MLFLOW_TRACKING_URI=http://localhost:${MLFLOW_PORT}

# ── Seshat config overrides ───────────────────────────────────────────────────

VECTOR_INDEX__EMBEDDING_PROVIDER=azure_openai
VECTOR_INDEX__EMBEDDING_MODEL=text-embedding-ada-002

EXTRACTION__IDENTIFICATION__PROVIDER=bedrock_converse
EXTRACTION__IDENTIFICATION__MODEL=eu.anthropic.claude-haiku-4-5-20251001-v1:0
EXTRACTION__GROUNDING__PROVIDER=azure_openai
EXTRACTION__GROUNDING__MODEL=gpt-5-nano
EXTRACTION__RESOLUTION__PROVIDER=bedrock_converse
EXTRACTION__RESOLUTION__MODEL=eu.anthropic.claude-haiku-4-5-20251001-v1:0
EXTRACTION__IDENTIFICATION_SELF_REVIEW__ENABLED=false
EXTRACTION__RESOLUTION_SELF_REVIEW__ENABLED=false
# Calibrated at p_target=0.95 with grounding=None (heuristics-only); re-run after enabling grounding
EXTRACTION__CONFIDENCE_THRESHOLD=0.76

# Search mode for the vector index; can be "semantic" (default), "keyword", or "hybrid"
RAG__SEARCH_MODE=semantic
# only needed if search mode involves keyword extraction
RAG__KEYWORD_EXTRACTION_LLM__PROVIDER=azure_openai
RAG__KEYWORD_EXTRACTION_LLM__MODEL=gpt-4o-mini

# ── Eval thresholds (optional) ────────────────────────────────────────────────
# Set by RetrievalMetaScorer calibration (argmax macro-F2).
# EVAL__RETRIEVAL_SCORE_THRESHOLDS__SEMANTIC=
# EVAL__RETRIEVAL_SCORE_THRESHOLDS__KEYWORD=
# EVAL__RETRIEVAL_SCORE_THRESHOLDS__HYBRID=
